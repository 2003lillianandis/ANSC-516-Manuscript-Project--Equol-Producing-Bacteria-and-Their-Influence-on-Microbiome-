
Qiime2 Scripts: 

Log in to Cluster: 
ssh <user.name>@bell.rcac.purdue.edu

Join Bell: 
slist                         
squeue -A microbiome      
sinteractive -A microbiome -p cpu -t 2:30:00 -n4

Load Modules: 
module load biocontainers
module load qiime2
module list

Upload Metadata and Sequence Data: 
scp /Users/lillianandis/Downloads/Metadata_Equol_v2.txt andis@bell.rcac.purdue.edu:/depot/microbiome/data/ANSC516/lillian_andis/ANSC516Project/
scp /Users/lillianandis/Downloads/hr04314_Anna-Clapp-Organski-Pool andis@bell.rcac.purdue.edu:/depot/microbiome/data/ANSC516/lillian_andis/ANSC516Project/

qiime tools import \
  --type EMPSingleEndSequences \
  --input-path emp-single-end-sequences \
  --output-path emp-single-end-sequences.qza

Demultiplexing sequences: 
qiime demux emp-single \
  --i-seqs emp-single-end-sequences.qza \
  --m-barcodes-file Metadata_Equol_v2.txt \
  --m-barcodes-column barcode-sequence \
  --o-per-sample-sequences demux.qza \
  --o-error-correction-details demux-details.qza

qiime demux summarize \
  --i-data demux.qza \
  --o-visualization demux.qzv

DADA2: 
qiime dada2 denoise-paired \
  --i-demultiplexed-seqs demux.qza \
  --p-trim-left-f 15 \
  --p-trim-left-r 15 \
  --p-trunc-len-f 150 \
  --p-trunc-len-r 150 \
  --p-n-threads 40\
  --o-representative-sequences rep-seqs-dada2.qza \
  --o-table table-dada2.qza \
  --o-denoising-stats stats-dada2.qza

qiime metadata tabulate \
  --m-input-file stats-dada2.qza \
  --o-visualization stats-dada2.qzv

mv rep-seqs-dada2.qza rep-seqs.qza
mv table-dada2.qza table.qza

