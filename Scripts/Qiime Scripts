Taxonomic analysis: 
wget \
  -O "gg-13-8-99-515-806-nb-classifier.qza" \
  "https://data.qiime2.org/classifiers/sklearn-1.4.2/greengenes/gg-13-8-99-515-806-nb-classifier.qza"

qiime feature-classifier classify-sklearn \
  --i-classifier gg-13-8-99-515-806-nb-classifier.qza \
  --i-reads rep-seqs.qza \
  --o-classification taxonomy.qza

qiime metadata tabulate \
  --m-input-file taxonomy.qza \
  --o-visualization taxonomy.qzv

qiime taxa barplot \
  --i-table table.qza \
  --i-taxonomy taxonomy.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --o-visualization taxa-bar-plots.qzv

Differential abundance testing with ANCOM-BC
Subset 1- 
qiime composition ancombc \
  --i-table 947-table.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-formula 'Treatment' \
  --o-differentials ancombc-947.qza

qiime composition da-barplot \
  --i-data 947-subject.qza \
  --p-significance-threshold 0.05 \
  --o-visualization da-barplot-947.qzv

qiime taxa collapse \
  --i-table 947-table.qza \
  --i-taxonomy taxonomy.qza \
  --p-level 6 \
  --o-collapsed-table 947-table-l6.qza

qiime composition ancombc \
  --i-table 947-table-l6.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-formula 'Treatment' \
  --o-differentials l6-ancombc-947.qza

qiime composition da-barplot \
  --i-data l6-ancombc-947.qza \
  --p-significance-threshold 0.05 \
  --p-level-delimiter ';' \
  --o-visualization l6-da-barplot-947.qzv

Subset 2- 
