Qiime2 Scripts: 

Log in to Cluster: 

Join Bell: 
slist                             
sinteractive -A microbiome -p cpu -t 2:30:00 -n4

Load Modules: 
module load biocontainers
module load qiime2
module list

Upload Metadata and Sequence Data: 
scp /Users/lillianandis/Downloads/Metadata_Equol_v2.txt andis@bell.rcac.purdue.edu:/depot/microbiome/data/ANSC516/lillian_andis/ANSC516Project/
scp /Users/lillianandis/Downloads/hr04314_Anna-Clapp-Organski-Pool andis@bell.rcac.purdue.edu:/depot/microbiome/data/ANSC516/lillian_andis/ANSC516Project/

qiime tools import \
  --type EMPSingleEndSequences \
  --input-path emp-single-end-sequences \
  --output-path emp-single-end-sequences.qza

Demultiplexing sequences: 
qiime demux emp-single \
  --i-seqs emp-single-end-sequences.qza \
  --m-barcodes-file Metadata_Equol_v2.txt \
  --m-barcodes-column barcode-sequence \
  --o-per-sample-sequences demux.qza \
  --o-error-correction-details demux-details.qza

qiime demux summarize \
  --i-data demux.qza \
  --o-visualization demux.qzv

DADA2: 
qiime dada2 denoise-paired \
  --i-demultiplexed-seqs demux.qza \
  --p-trim-left-f 15 \
  --p-trim-left-r 15 \
  --p-trunc-len-f 150 \
  --p-trunc-len-r 150 \
  --p-n-threads 40\
  --o-representative-sequences rep-seqs-dada2.qza \
  --o-table table-dada2.qza \
  --o-denoising-stats stats-dada2.qza

qiime metadata tabulate \
  --m-input-file stats-dada2.qza \
  --o-visualization stats-dada2.qzv

mv rep-seqs-dada2.qza rep-seqs.qza
mv table-dada2.qza table.qza

Feature Table: 
qiime feature-table summarize \
  --i-table table.qza \
  --o-visualization table.qzv \
  --m-sample-metadata-file Metadata_Equol_v2.txt

qiime feature-table tabulate-seqs \
  --i-data rep-seqs.qza \
  --o-visualization rep-seqs.qzv

Subset Data: 

qiime feature-table filter-samples \
  --i-table table.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-where "[Treatment]='947'" \
  --o-filtered-table 947-table.qza

qiime feature-table summarize \
  --i-table 947-table.qza \
  --o-visualization 947-table.qzv \
  --m-sample-metadata-file Metadata_Equol_v2.txt 

qiime feature-table filter-samples \
  --i-table table.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-where "[Treatment]='976'" \
  --o-filtered-table 976-table.qza

qiime feature-table summarize \
  --i-table 976-table.qza \
  --o-visualization 976-table.qzv \
  --m-sample-metadata-file Metadata_Equol_v2.txt 

Generate a tree for phylogenetic diversity analyses: 
qiime phylogeny align-to-tree-mafft-fasttree \
  --i-sequences rep-seqs.qza \
  --o-alignment aligned-rep-seqs.qza \
  --o-masked-alignment masked-aligned-rep-seqs.qza \
  --o-tree unrooted-tree.qza \
  --o-rooted-tree rooted-tree.qza

Alpha and beta diversity analysis: 

Subset 1- 
qiime diversity core-metrics-phylogenetic \
  --i-phylogeny rooted-tree.qza \
  --i-table 947-table.qza \
  --p-sampling-depth 80000 \
  --m-metadata-file Metadata_Equol_v2.txt \
  --output-dir core-metrics-results-947 

qiime diversity alpha-group-significance \
  --i-alpha-diversity core-metrics-results-947/faith_pd_vector.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --o-visualization core-metrics-results-947/faith-pd-group-significance.qzv

qiime diversity alpha-group-significance \
  --i-alpha-diversity core-metrics-results-947/evenness_vector.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --o-visualization core-metrics-results-947/evenness-group-significance.qzv

qiime diversity beta-group-significance \
  --i-distance-matrix core-metrics-results-947/unweighted_unifrac_distance_matrix.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --m-metadata-column Treatment \
  --o-visualization core-metrics-results-947/unweighted-unifrac-body-site-significance.qzv \
  --p-pairwise

qiime diversity beta-group-significance \
  --i-distance-matrix core-metrics-results-947/unweighted_unifrac_distance_matrix.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --m-metadata-column Treatment \
  --o-visualization core-metrics-results-947/unweighted-unifrac-subject-group-significance.qzv \
  --p-pairwise

qiime emperor plot \
  --i-pcoa core-metrics-results-947/unweighted_unifrac_pcoa_results.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-custom-axes Treatment \
  --o-visualization core-metrics-results-947/unweighted-unifrac-emperor-days-since-experiment-start.qzv

qiime emperor plot \
  --i-pcoa core-metrics-results-947/bray_curtis_pcoa_results.qza \
  --m-metadata-file Metadata_Equol_v2.txt \
  --p-custom-axes Treatment \
  --o-visualization core-metrics-results-947/bray-curtis-emperor-days-since-experiment-start.qzv

